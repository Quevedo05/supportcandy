# Configuración de API
# =====================

# URL base de la API
# Para desarrollo local: http://localhost:3000/api
# Para producción: https://api.agenciacalidad.gob.ar/api
VITE_API_URL=http://localhost:3000/api

# Usar localStorage en lugar de API
# true = usa localStorage (desarrollo sin servidor)
# false o no definido = usa API real
VITE_USE_LOCAL_STORAGE=true

# Timeout para requests HTTP (en milisegundos)
VITE_REQUEST_TIMEOUT=30000

# Modo debug
VITE_DEBUG=false
