# Google Sheets — integración automática de tickets
# Paso 1: Crear proyecto en console.cloud.google.com y habilitar "Google Sheets API"
# Paso 2: Crear Service Account, descargar el JSON de credenciales
# Paso 3: Compartir el Google Sheet con el email del service account (permiso Editor)
# Paso 4: Copiar el ID del Sheet desde la URL: docs.google.com/spreadsheets/d/[ID]/edit
GOOGLE_SHEETS_SPREADSHEET_ID=
# Paso 5: Pegar aquí el contenido COMPLETO del JSON de credenciales (en una sola línea)
GOOGLE_SERVICE_ACCOUNT_KEY=
